# Port the API listens on (defaults to 3000 if unset)
PORT=3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/ecommerce

# Secret used to sign JWT auth tokens — use a long, random string in production
JWT_SECRET=replace-with-a-long-random-string

# Email (Gmail). EMAIL_PASS must be a Gmail App Password, NOT your account password.
# Create one at: https://support.google.com/accounts/answer/185833
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-16-char-app-password

# Cloudinary credentials for image uploads — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
